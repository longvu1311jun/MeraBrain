# Lark app credentials.
# Put real values in .env.local for local dev and Vercel Environment Variables for deploy.
LARK_APP_ID=
LARK_APP_SECRET=

# Recommended for webhook verification. Leave empty only for first local smoke test.
LARK_VERIFICATION_TOKEN=

# Required only when Encrypt Key is enabled in Lark Events & Callbacks.
LARK_ENCRYPT_KEY=
